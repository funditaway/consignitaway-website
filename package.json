{
  "name": "consignitaway-website",
  "version": "1.0.0",
  "description": "Consign It Away - Springfield consignment marketplace",
  "scripts": {
    "start": "npx --yes serve . -p 3000",
    "dev": "npx --yes serve . -p 3000",
    "deploy:cf": "npx wrangler pages deploy . --project-name=consignitaway",
    "deploy:worker": "npx wrangler deploy --config wrangler-worker.toml",
    "dns:update": "powershell -ExecutionPolicy Bypass -File deploy-dns.ps1",
    "dns:godaddy": "powershell -ExecutionPolicy Bypass -File deploy-dns-godaddy.ps1",
    "import:catalog": "powershell -ExecutionPolicy Bypass -File scripts/import-catalog.ps1",
    "setup:worker": "powershell -ExecutionPolicy Bypass -File scripts/setup-worker.ps1"
  }
}